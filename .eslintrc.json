{
  "root": true,
  "ignorePatterns": [
    "projects/**/*"
  ],
  "overrides": [
    {
      "files": [
        "*.ts"
      ],
      "parserOptions": {
        "project": [
          "tsconfig.eslint.json"
        ],
        "createDefaultProgram": true
      },
      "extends": [
        "plugin:@angular-eslint/recommended",
        "plugin:@angular-eslint/template/process-inline-templates"
      ],
      "rules": {
        "@angular-eslint/directive-selector": [
          "error",
          {
            "type": "attribute",
            "prefix": "vl",
            "style": "camelCase"
          }
        ],
        "@angular-eslint/component-selector": [
          "error",
          {
            "type": "element",
            "prefix": "vl",
            "style": "kebab-case"
          }
        ],
        "no-empty-function": "off",
        "@typescript-eslint/no-empty-function": "off",
        "@angular-eslint/no-empty-lifecycle-method": "off",
        "@angular-eslint/no-input-rename": "off"
      }
    },
    {
      "files": [
        "src/app/shared/**/*.ts",
        "src/app/shell/**/*.ts"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@modules/*",
                  "**/project",
                  "**/project/**",
                  "**/modules",
                  "**/modules/**",
                  "**/demo",
                  "**/demo/**"
                ],
                "message": "Master layers must not import project, module, or demo code."
              }
            ]
          }
        ]
      }
    },
    {
      "files": [
        "src/app/core/**/*.ts"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@shared/*",
                  "@shell/*",
                  "@modules/*",
                  "**/shared",
                  "**/shared/**",
                  "**/shell",
                  "**/shell/**",
                  "**/project",
                  "**/project/**",
                  "**/modules",
                  "**/modules/**",
                  "**/demo",
                  "**/demo/**"
                ],
                "message": "Core must not import shared, shell, or consumer code."
              }
            ]
          }
        ]
      }
    },
    {
      "files": [
        "*.html"
      ],
      "extends": [
        "plugin:@angular-eslint/template/recommended"
      ],
      "rules": {}
    }
  ]
}
