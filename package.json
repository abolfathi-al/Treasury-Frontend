{
  "name": "enterprise-dashboard-master-source",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200",
    "start:ssr": "ng serve --port 4000 --configuration development",
    "build": "ng build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.spec.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "i18n:validate": "node scripts/validate-velora-shell-i18n.mjs",
    "i18n:inventory": "node scripts/validate-velora-shell-i18n.mjs --write-json",
    "build:prod": "ng build --base-href / --configuration production --stats-json",
    "postbuild:prod": "pnpm purgecss && pnpm sourceMap",
    "watch": "ng build --watch --configuration development",
    "rtl": "node scripts/rtl.js",
    "purgecss": "node scripts/purgecss.js",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "lint": "ng lint",
    "serve:ssr": "node dist/web/server/main.js",
    "build:ssr": "pnpm build:prod && ng run web:server",
    "dev:ssr": "ng run web:serve-ssr",
    "prerender": "ng run web:prerender",
    "analyze:prod": "webpack-bundle-analyzer dist/web/stats.json",
    "sourceMap": "node -e \"const fs=require(\\\"fs\\\"); const path=require(\\\"path\\\"); const dir=path.resolve(\\\"dist/web\\\"); const out=path.join(dir,\\\"sourceMaps\\\"); if(!fs.existsSync(dir)) process.exit(0); fs.mkdirSync(out,{recursive:true}); for(const file of fs.readdirSync(dir)){ if(file.endsWith(\\\".map\\\")) fs.renameSync(path.join(dir,file), path.join(out,file)); }\"",
    "patch:tiny-slider": "patch-package tiny-slider",
    "figma-mcp": "node scripts/figma-mcp.js",
    "figma-mcp:stdio": "node scripts/figma-mcp.js stdio",
    "figma-mcp:dev": "node scripts/figma-mcp.js dev",
    "figma-mcp:stop": "node scripts/figma-mcp.js stop",
    "figma-mcp:http": "node scripts/figma-mcp.js http"
  },
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@angular/animations": "20.3.3",
    "@angular/common": "20.3.3",
    "@angular/compiler": "20.3.3",
    "@angular/core": "20.3.3",
    "@angular/forms": "20.3.3",
    "@angular/localize": "20.3.3",
    "@angular/platform-browser": "20.3.3",
    "@angular/platform-browser-dynamic": "20.3.3",
    "@angular/platform-server": "20.3.3",
    "@angular/router": "20.3.3",
    "@angular/service-worker": "20.3.3",
    "@angular/ssr": "20.3.3",
    "@fullcalendar/bootstrap5": "^6.1.19",
    "@fullcalendar/core": "^6.1.19",
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/interaction": "^6.1.19",
    "@fullcalendar/list": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19",
    "@ng-bootstrap/ng-bootstrap": "^19.0.1",
    "@ng-select/ng-select": "^16.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@popperjs/core": "^2.11.8",
    "@types/bootstrap-maxlength": "^1.7.35",
    "@types/dropzone": "^5.7.9",
    "@types/flatpickr": "^3.0.2",
    "@yaireo/tagify": "^4.35.4",
    "animate.css": "4.1.1",
    "autosize": "^6.0.1",
    "awesomplete": "^1.1.7",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "clipboard": "^2.0.11",
    "countup.js": "^2.9.0",
    "d3": "^7.9.0",
    "dropzone": "^5.9.3",
    "express": "^5.1.0",
    "file-saver": "^2.0.5",
    "flatpickr-wrap": "^1.0.0",
    "jkanban": "^1.3.1",
    "md5": "^2.3.0",
    "native-date-adapter": "^1.0.3",
    "ng-inline-svg-2": "^20.0.1",
    "ngx-permissions": "^19.0.0",
    "ngx-toastr": "^19.1.0",
    "prism-themes": "1.9.0",
    "rxjs": "^7.8.2",
    "socicon": "3.0.5",
    "sweetalert2": "^11.23.0",
    "tiny-slider": "^2.9.4",
    "typed.js": "^2.1.0"
